# === LLM Provider Configuration ===
# Supported: openai | qwen | openrouter | mock
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1

# === Vision Model (for screenshot analysis) ===
VISION_PROVIDER=mock
VISION_MODEL=gpt-4o
VISION_API_KEY=your-api-key-here
VISION_BASE_URL=https://api.openai.com/v1

# === Discovery Sources ===
EXA_API_KEY=your-exa-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_API_KEY=your-mapbox-api-key

# === Email Configuration ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Your Name
EMAIL_FROM_ADDRESS=your-email@gmail.com

# Safety valve: while true, outreach emails are redirected to DRY_RUN_RECIPIENT
# instead of the real lead's email. Set to false to send to real businesses.
MAIL_DRY_RUN=true
# Inbox that receives redirected emails while MAIL_DRY_RUN=true.
DRY_RUN_RECIPIENT=your-test-inbox@example.com

# === Application Settings ===
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///data/app.db
MAX_LEADS=5
DEFAULT_LOCATION=Singapore
DEFAULT_COUNTRY=SG

# === Playwright ===
PLAYWRIGHT_BROWSERS_PATH=0
